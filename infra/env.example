# Copy to .env and fill in values (do not commit secrets).
DATABASE_URL=sqlite:///./local.db
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/codex
# REDIS_URL=redis://localhost:6379/0
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=

# Operator routes (/jobs, /approvals, /audit, /email): set to require X-Operator-Key header
# OPERATOR_API_KEY=

# Gmail: stub (default) or live worker/API path
# GMAIL_MODE=stub
# GMAIL_MODE=live
# Gmail live API (optional): pip install -e ".[gmail]" then OAuth user token JSON path
# GMAIL_CREDENTIALS_PATH=

# Manual integration tests (tests/test_gmail_live_integration.py):
# GMAIL_INTEGRATION_TEST=1
# GMAIL_TEST_THREAD_ID=
# GMAIL_TEST_CREATE_DRAFT=1

# Operator docs: docs/GMAIL_OPERATOR_RUNBOOK.md, docs/LIVE_GMAIL_SETUP.md
# Demo: scripts/demo_gmail_flow.sh (bash; from repo root with PYTHONPATH=.)
